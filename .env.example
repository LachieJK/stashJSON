# Copy to `.env` and fill in. Values below work with the local docker-compose Postgres.

# --- Database (required) ---
# Local Postgres (docker compose up -d), or a Neon connection string in prod.
# Consumed twice: the app connects through the pg driver adapter (lib/db.ts), and
# the Prisma CLI reads it via prisma.config.ts (Prisma 7 no longer auto-loads .env,
# hence the `dotenv/config` import there).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stashjson?schema=public"

NODE_ENV="development"

# --- Web auth: Better Auth (required in production) ---
# In dev/test these fall back to insecure defaults (see lib/env.ts), so you can
# leave them unset locally. In production BOTH are mandatory.
#
# Generate a strong secret, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET="dev-only-insecure-secret-change-in-production"
# Absolute base URL of the app (used for cookies/redirects).
BETTER_AUTH_URL="http://localhost:3000"
