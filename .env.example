# PostgreSQL connection string used by Prisma.
#
# Production (Neon): copy the pooled connection string from the Neon dashboard, e.g.
#   DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/stashjson?sslmode=require"
#
# Local development (Docker): run `docker compose up -d` (see docker-compose.yml) and use:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stashjson?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stashjson?schema=public"
