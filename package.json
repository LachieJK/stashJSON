{
  "name": "stashjson",
  "version": "2.0.0",
  "private": true,
  "description": "Simple JSON document storage — Next.js + Prisma rewrite",
  "engines": {
    "node": "^20.19 || ^22.12 || >=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "docker compose up -d && TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stashjson_test?schema=public vitest run",
    "test:unit-only": "vitest run",
    "test:watch": "docker compose up -d && TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stashjson_test?schema=public vitest",
    "test:coverage": "docker compose up -d && TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stashjson_test?schema=public vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-auth": "^1.6.23",
    "nanoid": "^5.0.9",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.1.4",
    "postcss": "^8.5.16",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
