// StashJSON data model.
// Ported from the legacy SQLAlchemy models in legacy/app/database.py.
// Key change: JSON is stored natively as `Json` (JSONB) instead of serialized Text.

generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

// The connection URL lives in prisma.config.ts (Prisma 7 no longer accepts
// `url` here); the runtime client gets it via the pg driver adapter in lib/db.ts.
datasource db {
  provider = "postgresql"
}

// The human identity. Web login (email/password) is handled by Better Auth,
// which owns the Session/Account/Verification tables below and expects the
// `name`, `email`, `emailVerified`, `image`, and `updatedAt` fields here.
// Public REST API keys live in the separate `ApiKey` table (many per user).

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  emailVerified    Boolean  @default(false) @map("email_verified")
  image            String?
  tier             PlanTier @default(FREE)
  // Billing seam — populated in the subscriptions stage; unwired for now.
  stripeCustomerId String?  @unique @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspaces Workspace[]
  documents  Document[]
  apiKeys    ApiKey[]
  sessions   Session[]
  accounts   Account[]

  @@map("users")
}

// Subscription tier. Billing (Stripe) is wired in the next stage; for now this
// just records what plan a user is on, defaulting everyone to FREE.

enum PlanTier {
  FREE
  PRO
  TEAM
}

// Public programmatic API keys (the `X-API-Key` contract). Stored SHA-256
// hashed, never plaintext (see lib/utils.ts). A user may hold several — rotate
// a leaked key by revoking it and issuing a new one without losing documents.

model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  keyHash    String    @unique @map("key_hash")
  name       String
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

// --- Better Auth tables (web sessions / credentials). Field names match what
// Better Auth expects; @map keeps DB columns snake_case per repo convention. ---

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

model Workspace {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]
  template  WorkspaceTemplate?

  @@index([userId])
  @@map("workspaces")
}

model WorkspaceTemplate {
  id          String   @id @default(uuid())
  workspaceId String   @unique @map("workspace_id")
  jsonSchema  Json     @map("json_schema")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_templates")
}

model Document {
  // 16-char nanoid, generated in application code (see lib/utils.ts).
  id          String   @id
  userId      String   @map("user_id")
  workspaceId String?  @map("workspace_id")
  jsonData    Json     @map("json_data")
  isPublic    Boolean  @default(false) @map("is_public")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Deleting a workspace nulls the FK; the document itself survives.
  workspace Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  versions  DocumentVersion[]

  @@index([userId])
  @@index([workspaceId])
  @@map("documents")
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  jsonData   Json     @map("json_data")
  version    Int
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_versions")
}
